{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/agent-learning-lab.db"
  },
  "OpenAI": {
    "Model": "",
    "EnableDevelopmentResponseDiagnostics": false
  },
  "Agent": {
    "DefaultExecutionMode": "Offline",
    "MaximumSteps": 8,
    "MaximumRecentMessages": 20
  },
  "Approval": {
    "ExpirationMinutes": 15
  },
  "Retrieval": {
    "MaximumResults": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
