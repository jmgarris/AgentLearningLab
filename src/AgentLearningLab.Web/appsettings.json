{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/agent-learning-lab.db"
  },
  "OpenAI": {
    "Model": "gpt-5.6-terra"
  },
  "Agent": {
    "MaximumSteps": 8,
    "MaximumRecentMessages": 20
  },
  "Approval": {
    "ExpirationMinutes": 15
  },
  "Retrieval": {
    "MaximumResults": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
