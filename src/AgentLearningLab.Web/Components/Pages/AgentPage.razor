@page "/agent"
@implements IDisposable
@using AgentLearningLab.Application.Abstractions
@using AgentLearningLab.Domain.Enums
@inject AgentLearningLab.Agent.AgentRunner AgentRunner
@inject AgentLearningLab.Web.Services.DemoIdentityService IdentityService
@inject IConversationStore ConversationStore

<PageTitle>Agent Lab</PageTitle>

<h1>ClubOps Learning Agent</h1>

@if (!IdentityService.IsEnabled)
{
    <p>This page requires the Development environment because the sample uses a development-only identity switcher.</p>
}
else
{
    <div class="agent-layout">
        <section class="panel transcript-panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Conversation</p>
                    <h2>Interactive agent run</h2>
                </div>
                <div class="conversation-tools">
                    <select @bind="selectedConversationIdString" @bind:after="HandleConversationChangedAsync">
                        <option value="">New conversation</option>
                        @foreach (var conversation in conversations)
                        {
                            <option value="@conversation.ConversationId.ToString()">@conversation.Title</option>
                        }
                    </select>
                    <button type="button" class="quiet-button" @onclick="ClearConversationAsync" disabled="@busy">Clear conversation</button>
                </div>
            </div>

            <div class="identity-chip">Active user: @currentUser?.Email (@currentUser?.Role)</div>

            @if (busy)
            {
                <div class="busy-indicator">Agent is working through the current step loop...</div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="error-banner">@errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="success-banner">@successMessage</div>
            }

            <div class="transcript">
                @if (transcript.Count == 0)
                {
                    <div class="empty-state">Start with a prompt like "What is the current status of N123AB?"</div>
                }
                else
                {
                    @foreach (var item in transcript)
                    {
                        <article class="message-card @item.Kind.ToString().ToLowerInvariant()">
                            <div class="message-meta">
                                <span>@item.Sender</span>
                                <span>@item.CreatedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                            </div>
                            <p>@item.Content</p>
                        </article>
                    }
                }
            </div>

            <EditForm Model="this" FormName="agent-message-form" OnValidSubmit="SendAsync">
                <div class="composer">
                    <textarea
                        class="composer-input"
                        @bind="messageText"
                        @bind:event="oninput"
                        placeholder="Ask about a fictional aircraft, club rule, or maintenance workflow..."></textarea>
                    <button class="primary-button" type="submit" disabled="@(!CanSend)">Send</button>
                </div>
            </EditForm>
        </section>

        <aside class="panel side-panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Trace</p>
                    <h2>Tool activity</h2>
                </div>
            </div>

            <ol class="step-list">
                @foreach (var step in latestSteps)
                {
                    <li>@step.Summary</li>
                }
            </ol>

            @if (latestResult?.Citations.Count > 0)
            {
                <div class="citation-box">
                    <h3>Citations</h3>
                    <ul>
                        @foreach (var citation in latestResult.Citations)
                        {
                            <li>@citation.DisplayText</li>
                        }
                    </ul>
                </div>
            }

            @if (latestResult?.PendingApproval is not null)
            {
                <div class="approval-card">
                    <p class="eyebrow">Approval required</p>
                    <h3>@latestResult.PendingApproval.ToolName</h3>
                    <p>@latestResult.PendingApproval.ActionSummary</p>
                    <p>Expires: @latestResult.PendingApproval.ExpiresAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</p>

                    @if (currentUser?.Role == ClubRole.Administrator)
                    {
                        <div class="approval-actions">
                            <button class="primary-button" @onclick="ApproveAsync" disabled="@busy">Approve</button>
                            <button class="quiet-button" @onclick="RejectAsync" disabled="@busy">Reject</button>
                        </div>
                    }
                    else
                    {
                        <p class="note-text">Only an administrator can approve this action.</p>
                    }
                </div>
            }
        </aside>
    </div>
}

@code {
    private readonly CancellationTokenSource componentCts = new();
    private AuthenticatedUserContext? currentUser;
    private string messageText = string.Empty;
    private string? errorMessage;
    private string? successMessage;
    private bool busy;
    private string selectedConversationIdString = string.Empty;
    private string? activeUserEmail;
    private IReadOnlyList<ConversationSummaryViewModel> conversations = [];
    private IReadOnlyList<ConversationTranscriptItem> transcript = [];
    private AgentRunResult? latestResult;
    private IReadOnlyList<AgentStepSummary> latestSteps = [];

    private bool CanSend => !busy && !string.IsNullOrWhiteSpace(messageText);

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync(resetConversationStateWhenUserChanges: true);
    }

    private async Task RefreshAsync(bool resetConversationStateWhenUserChanges = false)
    {
        var user = await IdentityService.GetCurrentUserAsync(componentCts.Token);
        var userChanged = !string.Equals(activeUserEmail, user.Email, StringComparison.OrdinalIgnoreCase);

        currentUser = user;
        activeUserEmail = user.Email;

        if (userChanged && resetConversationStateWhenUserChanges)
        {
            ResetConversationState(clearMessageText: false);
        }

        conversations = await ConversationStore.ListConversationsAsync(currentUser.Email, componentCts.Token);
        await LoadSelectedConversationAsync();
    }

    private async Task LoadSelectedConversationAsync()
    {
        if (!Guid.TryParse(selectedConversationIdString, out var conversationId))
        {
            transcript = [];
            return;
        }

        if (!conversations.Any(x => x.ConversationId == conversationId))
        {
            ResetConversationState(clearMessageText: false);
            return;
        }

        transcript = await ConversationStore.GetTranscriptAsync(conversationId, componentCts.Token);
    }

    private async Task SendAsync()
    {
        if (currentUser is null)
        {
            return;
        }

        var trimmedMessage = messageText.Trim();
        if (string.IsNullOrWhiteSpace(trimmedMessage))
        {
            return;
        }

        busy = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            Guid? conversationId = Guid.TryParse(selectedConversationIdString, out var parsedConversationId)
                ? parsedConversationId
                : null;

            latestResult = await AgentRunner.RunAsync(conversationId, trimmedMessage, currentUser, componentCts.Token);
            selectedConversationIdString = latestResult.ConversationId.ToString();
            latestSteps = latestResult.Steps;
            messageText = string.Empty;
            await RefreshAsync();
        }
        catch (OperationCanceledException) when (componentCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ApproveAsync()
    {
        if (currentUser is null || latestResult?.PendingApproval is null)
        {
            return;
        }

        busy = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            latestResult = await AgentRunner.ApproveAsync(latestResult.PendingApproval.ApprovalRequestId, currentUser, componentCts.Token);
            latestSteps = latestResult.Steps;
            await RefreshAsync();
        }
        catch (OperationCanceledException) when (componentCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task RejectAsync()
    {
        if (currentUser is null || latestResult?.PendingApproval is null)
        {
            return;
        }

        busy = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            latestResult = await AgentRunner.RejectAsync(latestResult.PendingApproval.ApprovalRequestId, currentUser, componentCts.Token);
            latestSteps = latestResult.Steps;
            await RefreshAsync();
        }
        catch (OperationCanceledException) when (componentCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ClearConversationAsync()
    {
        if (busy)
        {
            return;
        }

        errorMessage = null;

        if (currentUser is null)
        {
            return;
        }

        if (!Guid.TryParse(selectedConversationIdString, out var conversationId))
        {
            ResetConversationState(
                clearMessageText: true,
                newSuccessMessage: "Conversation cleared. Your next message will start a new conversation.");
            return;
        }

        busy = true;
        successMessage = null;

        try
        {
            await ConversationStore.ArchiveConversationAsync(conversationId, currentUser, componentCts.Token);
            ResetConversationState(
                clearMessageText: true,
                newSuccessMessage: "Conversation cleared. Your next message will start a new conversation.");
            await RefreshAsync();
        }
        catch (OperationCanceledException) when (componentCts.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task HandleConversationChangedAsync()
    {
        errorMessage = null;
        successMessage = null;
        latestResult = null;
        latestSteps = [];

        await LoadSelectedConversationAsync();
    }

    private void ResetConversationState(bool clearMessageText, string? newSuccessMessage = null)
    {
        selectedConversationIdString = string.Empty;
        transcript = [];
        latestResult = null;
        latestSteps = [];
        errorMessage = null;
        successMessage = newSuccessMessage;

        if (clearMessageText)
        {
            messageText = string.Empty;
        }
    }

    public void Dispose()
    {
        if (!componentCts.IsCancellationRequested)
        {
            componentCts.Cancel();
        }

        componentCts.Dispose();
    }
}
