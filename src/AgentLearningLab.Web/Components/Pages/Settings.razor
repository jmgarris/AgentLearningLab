@page "/settings"
@inject AgentLearningLab.Agent.ModelRuntimeInfo RuntimeInfo
@inject AgentLearningLab.Agent.IRuntimeModePreferenceStore RuntimeModePreferenceStore

<PageTitle>Settings</PageTitle>

<h1>Runtime Settings</h1>

<div class="settings-grid">
    <section class="panel">
        <p class="eyebrow">Execution Mode</p>
        <h2>Choose how the agent responds</h2>
        <p class="lead">
            Use offline mode for deterministic local learning, or use the configured API key to call OpenAI directly for this session.
        </p>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error-banner">@errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="success-banner">@successMessage</div>
        }

        <EditForm Model="settings" FormName="runtime-mode-form" OnValidSubmit="SaveAsync" class="settings-form">
            <InputRadioGroup @bind-Value="settings.SelectedMode" Name="runtime-mode">
                <div class="choice-list">
                    <div class="choice-card @(settings.SelectedMode == AgentExecutionMode.Offline ? "selected" : null)">
                        <label>
                            <InputRadio Value="AgentExecutionMode.Offline" />
                            <span>
                                <strong>Offline mode</strong><br />
                                Uses the deterministic fake model and avoids live API calls or charges.
                            </span>
                        </label>
                    </div>

                    <div class="choice-card @(settings.SelectedMode == AgentExecutionMode.ApiKey ? "selected" : null)">
                        <label>
                            <InputRadio Value="AgentExecutionMode.ApiKey" disabled="@(!RuntimeInfo.IsApiModeAvailable)" />
                            <span>
                                <strong>API key mode</strong><br />
                                Uses `OPENAI_API_KEY` with the configured model `@(RuntimeInfo.IsModelConfigured ? RuntimeInfo.ActiveModelName : "<not configured>")`.
                            </span>
                        </label>
                    </div>
                </div>
            </InputRadioGroup>

            <div class="settings-actions">
                <button class="primary-button" type="submit">Save settings</button>
                <span class="status-pill @(RuntimeInfo.IsApiModeAvailable ? null : "warning")">
                    @(RuntimeInfo.IsApiModeAvailable ? "API mode available" : "API mode unavailable")
                </span>
            </div>
        </EditForm>
    </section>

    <aside class="panel">
        <p class="eyebrow">Current Session</p>
        <h2>Active runtime summary</h2>

        <p><strong>Current mode:</strong> @(RuntimeInfo.IsOffline ? "Offline" : "API key")</p>
        <p><strong>API key detected:</strong> @(RuntimeInfo.IsApiKeyAvailable ? "Yes" : "No")</p>
        <p><strong>Model configured:</strong> @(RuntimeInfo.IsModelConfigured ? "Yes" : "No")</p>
        <p><strong>Configured model name:</strong> @(RuntimeInfo.IsModelConfigured ? RuntimeInfo.ActiveModelName : "<blank>")</p>
        <p><strong>API mode available:</strong> @(RuntimeInfo.IsApiModeAvailable ? "Yes" : "No")</p>
        @if (!RuntimeInfo.IsApiModeAvailable && !string.IsNullOrWhiteSpace(RuntimeInfo.ApiModeUnavailableReason))
        {
            <p><strong>Availability note:</strong> @RuntimeInfo.ApiModeUnavailableReason</p>
        }

        <div class="citation-box">
            <h3>Notes</h3>
            <ul>
                <li>This setting applies immediately to the current Blazor session and is persisted in browser localStorage.</li>
                <li>Offline mode always uses the deterministic fake model.</li>
                <li>The API key itself is never stored in the browser.</li>
                <li>API key mode still depends on your OpenAI project having access to the configured model.</li>
            </ul>
        </div>
    </aside>
</div>

@code {
    private readonly RuntimeSettingsInput settings = new();
    private string? errorMessage;
    private string? successMessage;

    protected override void OnInitialized()
    {
        settings.SelectedMode = RuntimeInfo.SelectedMode;
    }

    private async Task SaveAsync()
    {
        errorMessage = null;
        successMessage = null;

        if (!RuntimeInfo.TrySetMode(settings.SelectedMode))
        {
            settings.SelectedMode = RuntimeInfo.SelectedMode;
            errorMessage = RuntimeInfo.ApiModeUnavailableReason ?? "API key mode is unavailable for this session.";
            return;
        }

        settings.SelectedMode = RuntimeInfo.SelectedMode;
        await RuntimeModePreferenceStore.SaveAsync(RuntimeInfo.SelectedMode, CancellationToken.None);
        successMessage = RuntimeInfo.IsOffline
            ? "Offline mode is now active for this session and will remain the browser default on this device."
            : $"API key mode is now active for this session using {RuntimeInfo.ActiveModelName}.";
    }

    private sealed class RuntimeSettingsInput
    {
        public AgentExecutionMode SelectedMode { get; set; }
    }
}
