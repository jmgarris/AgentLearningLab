@inherits LayoutComponentBase
@implements IDisposable
@inject AgentLearningLab.Agent.ModelRuntimeInfo RuntimeInfo
@inject AgentLearningLab.Agent.IRuntimeModePreferenceStore RuntimeModePreferenceStore

<div class="shell">
    <aside class="shell-nav">
        <div class="brand-block">
            <p class="eyebrow">AgentLearningLab</p>
            <h1>ClubOps Learning Agent</h1>
            <p>Explicit agent loops, approvals, retrieval, and evaluations in one solution.</p>
        </div>
        <AgentLearningLab.Web.Components.Shared.DevIdentitySwitcher />
        <NavMenu />
    </aside>

    <main class="shell-main">
        @if (RuntimeInfo.IsOffline)
        {
            <div class="mode-banner">Offline learning mode - responses are produced by a deterministic fake model.</div>
        }
        else if (RuntimeInfo.IsUsingApiKey)
        {
            <div class="mode-banner api-mode-banner">API key mode - requests use the configured OpenAI model `@RuntimeInfo.ActiveModelName`.</div>
        }

        <article class="content-wrap">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool _initializedFromPreference;

    protected override void OnInitialized()
    {
        RuntimeInfo.Changed += HandleRuntimeInfoChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initializedFromPreference)
        {
            return;
        }

        _initializedFromPreference = true;
        var preferredMode = await RuntimeModePreferenceStore.LoadAsync(CancellationToken.None);
        RuntimeInfo.ApplySavedPreference(preferredMode);
    }

    private void HandleRuntimeInfoChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        RuntimeInfo.Changed -= HandleRuntimeInfoChanged;
    }
}
